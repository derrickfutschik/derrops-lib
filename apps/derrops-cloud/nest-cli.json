{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "apps/derrops-cloud/src/main",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": false,
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": { "classValidatorShim": true }
      }
    ]
  }
}
