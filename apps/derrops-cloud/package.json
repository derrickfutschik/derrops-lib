{
  "name": "@derrops/cloud",
  "version": "0.1.0",
  "description": "Derrops Cloud Backend - NestJS API",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "build:backend": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "opensearch:migrate": "nest start -- opensearch:migrate",
    "opensearch:migrate:dev": "nest start -- opensearch:migrate",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/derrops-cloud/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "generate:openapi": "node dist/apps/derrops-cloud/src/openapi.js",
    "generate:client": "pnpm exec openapi-generator-cli generate -i dist/openapi.json -g typescript-axios -o ../derrops-portal/src/client/derrops-cloud --additional-properties=withSeparateModelsAndApi=true,apiPackage=api,modelPackage=models"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.972.0",
    "@aws-sdk/client-secrets-manager": "^3.972.0",
    "@aws-sdk/client-sqs": "^3.972.0",
    "@aws-sdk/credential-provider-node": "^3.972.0",
    "@aws-sdk/s3-request-presigner": "^3.972.0",
    "@codegenie/serverless-express": "^4.17.1",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^8.0.7",
    "@nestjs/typeorm": "^10.0.2",
    "@opensearch-project/opensearch": "^3.5.1",
    "@derrops/config": "workspace:*",
    "@derrops/config-nestjs": "workspace:*",
    "@derrops/private": "workspace:*",
    "aws-lambda": "^1.0.7",
    "body-parser": "^2.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jose": "^6.2.2",
    "jsonwebtoken": "^9.0.3",
    "openapi-types": "^12.1.3",
    "opensearch-ts": "^1.2.12",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20",
    "uuid": "^11.0.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@openapitools/openapi-generator-cli": "^2.27.0",
    "@types/aws-lambda": "^8.10.159",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.8",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.38.0"
  }
}
