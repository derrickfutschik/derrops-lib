{
  "name": "slaops-cli",
  "version": "0.1.0",
  "description": "SLAOps CLI — developer tooling for the SLAOps platform",
  "private": true,
  "license": "MIT",
  "bin": {
    "slaops": "./bin/run.js"
  },
  "main": "dist/index.js",
  "oclif": {
    "bin": "slaops",
    "dirname": "slaops",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help"
    ],
    "topicSeparator": " "
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@oclif/core": "^4.0.0",
    "@oclif/plugin-help": "^6.0.0",
    "slaops-relay": "workspace:*"
  },
  "optionalDependencies": {
    "@aws-sdk/client-sqs": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
