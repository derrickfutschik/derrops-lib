{
  // Editor-focused config (see package scripts); navigation shares repo-wide workspace paths.
  "extends": "../../tsconfig.library.json",
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "moduleResolution": "bundler",
    "noEmit": true,
    "baseUrl": "../../",
    "skipLibCheck": true,
    "strict": false
  },
  "exclude": [".docusaurus", "build"]
}
