# ── Server ──────────────────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ── Database (TypeORM / PostgreSQL) ─────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=slaops_relay
DB_SSL=false
DB_LOGGING=false

# ── Secret store ─────────────────────────────────────────────────────────────
# env | aws-secrets-manager | hashicorp-vault | azure-key-vault | gcp-secret-manager
RELAY_SECRET_BACKEND=env

# TTL in seconds for the in-process secret cache (0 to disable)
RELAY_SECRET_CACHE_TTL_S=300

# Prefetch comma-separated secret IDs on startup (optional)
# RELAY_SECRET_PREFETCH=MY_API_KEY,ANOTHER_SECRET

# ── Proxy behaviour ──────────────────────────────────────────────────────────
# Default request timeout in milliseconds
RELAY_PROXY_TIMEOUT_MS=30000

# Maximum response body size in bytes before truncation (default 10 MB)
RELAY_PROXY_MAX_BODY_BYTES=10485760

# ── HashiCorp Vault (if RELAY_SECRET_BACKEND=hashicorp-vault) ────────────────
# RELAY_VAULT_ADDR=http://127.0.0.1:8200
# RELAY_VAULT_TOKEN=dev-root-token
# RELAY_VAULT_MOUNT=secret
