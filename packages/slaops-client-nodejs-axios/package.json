{
  "name": "slaops-client-nodejs-axios",
  "version": "0.1.0",
  "description": "Axios-only client + interceptor for sending SLA Ops HTTP events from Node.js apps.",
  "keywords": [
    "slaops",
    "observability",
    "logging",
    "metrics",
    "client",
    "axios",
    "typescript"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/slaops-client-nodejs-axios.git",
    "directory": "packages/slaops-client-nodejs-axios"
  },
  "bugs": {
    "url": "https://github.com/your-org/slaops-client-nodejs-axios/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsc -w",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@slaops/client": "*",
    "@slaops/lib": "*"
  },
  "peerDependencies": {
    "axios": ">=1.6.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/node": "^22.7.8",
    "axios": "^1.7.7",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
