{
  "name": "@slaops/client-nodejs-axios",
  "version": "0.1.0",
  "description": "Axios-only client + interceptor for sending SLA Ops HTTP events from Node.js apps.",
  "private": false,
  "keywords": [
    "slaops",
    "observability",
    "logging",
    "metrics",
    "client",
    "axios",
    "typescript"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/slaops-client-nodejs-axios.git",
    "directory": "packages/slaops-client-nodejs-axios"
  },
  "bugs": {
    "url": "https://github.com/your-org/slaops-client-nodejs-axios/issues"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsc -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "dependencies": {
    "@slaops/client": "workspace:*",
    "@slaops/public": "workspace:*"
  },
  "peerDependencies": {
    "axios": ">=1.6.0"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": false
    }
  },
  "devDependencies": {
    "jest-md-dashboard": "^0.8.1",
    "@aws-sdk/client-dynamodb": "^3.940.0",
    "@aws-sdk/protocol-http": "^3.374.0",
    "@aws-sdk/types": "^3.936.0",
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.8",
    "axios": "^1.7.7",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  }
}
