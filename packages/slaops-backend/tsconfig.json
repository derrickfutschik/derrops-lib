{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "lib": ["ES2022"],
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": false,
    "baseUrl": "./",
    "paths": {
      "@slaops/backend/*": ["./amplify/*"],
      "@slaops/cloud/*": ["../../apps/slaops-cloud/src/*"]
    }
  },
  "include": ["amplify/**/*"],
  "exclude": ["node_modules", "dist", ".amplify"]
}
