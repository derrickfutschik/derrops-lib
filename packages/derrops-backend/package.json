{
  "name": "@derrops/backend",
  "description": "AWS Amplify Infrastructure for Derrops Platform",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "sandbox": "ampx sandbox",
    "deploy": "ampx deploy",
    "pull": "ampx pull",
    "clean": "rm -rf .amplify build node_modules dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@derrops/cloud": "workspace:*",
    "@derrops/config": "workspace:*",
    "@aws-amplify/backend": "^1.19.0",
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/credential-provider-node": "^3.500.0",
    "@opensearch-project/opensearch": "^2.12.0",
    "yaml": "^2.3.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0",
    "typescript": "^5.6.3"
  }
}
