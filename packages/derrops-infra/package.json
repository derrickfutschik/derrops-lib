{
  "name": "@derrops/infra",
  "description": "AWS CDK Infrastructure Stacks for Derrops Platform",
  "private": true,
  "version": "0.1.0",
  "type": "commonjs",
  "bin": {
    "derrops-infra": "bin/cdk.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsc --noEmit --watch",
    "typecheck": "tsc --noEmit",
    "cdk": "cdk",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "cdk deploy",
    "deploy:all": "cdk deploy --all",
    "destroy": "cdk destroy",
    "bootstrap": "cdk bootstrap",
    "clean": "rm -rf cdk.out node_modules dist"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.130.0",
    "constructs": "^10.3.0",
    "source-map-support": "^0.5.21",
    "@derrops/config": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.8",
    "aws-cdk": "^2.130.0",
    "typescript": "^5.6.3"
  }
}
