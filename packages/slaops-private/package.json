{
  "name": "@slaops/private",
  "version": "0.1.0",
  "description": "Core types and utilities for SLA Ops (private)",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsc -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@slaops/config": "workspace:*",
    "@slaops/test-resources": "*",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/lodash": "^4.17.0",
    "@types/node": "^22.7.8",
    "jest": "^29.7.0",
    "jest-md-dashboard": "^0.8.1",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@aws-sdk/client-dynamodb": "^3.940.0",
    "@aws-sdk/client-s3": "^3.940.0",
    "@aws-sdk/util-dynamodb": "^3.940.0",
    "@slaops/public": "workspace:*",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "oas": "^28.5.1",
    "openapi-request-validator": "^12.1.3",
    "openapi-types": "^12.1.3"
  }
}
