{
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,

  "singleQuote": true,
  "jsxSingleQuote": false,

  "semi": false,
  "trailingComma": "all",

  "arrowParens": "always",
  "bracketSpacing": true,
  "bracketSameLine": false,

  "endOfLine": "lf",

  "plugins": ["prettier-plugin-organize-imports"]
}
