# SLAOps Platform - tmuxinator environment variables
# Source before starting tmuxinator:
#   source .tmuxinator.env && tmuxinator start -p .tmuxinator.yml

# Common config
export SLAOPS_PROJECT_ROOT=~/slaops/slaops-platform

# Dev server
export DEVSERVER_IP=192.168.7.233
export DEVSERVER_USER=derrick
export DEVSERVER_PATH=/home/derrick/slaops/slaops-platform

# Service ports
export DOCS_PORT=3001
export PORTAL_PORT=3000
export CLOUD_PORT=8080
export RELAY_PORT=8081
export AEGIS_PORT=8082

# Derived service URLs (automatically reflect port changes above)
export AEGIS_ISSUER=http://localhost:${AEGIS_PORT}
export AEGIS_JWKS_URL=${AEGIS_ISSUER}/.well-known/jwks.json
export RELAY_URL=http://localhost:${RELAY_PORT}

# Relay config
export RELAY_QUEUE_BACKEND=memory
export RELAY_SECRET_BACKEND=env

# Aegis config
export AEGIS_SIGNING_KEY_ID=aegis-dev-1
export ALLOWED_RELAY_IDS=00000000-0000-0000-0000-000000relay1

# Cloudflare tunnels
export CF_TUNNEL_DEV=dev-8080
export CF_DNS_DEV=dev.dersza.com
export CF_STARTUP_DELAY=15

# Smoke test fixtures
export SMOKE_TENANT_ID=dev-tenant
export SMOKE_USER_TOKEN=dev-token-idp-validation-skipped
export SMOKE_API_ID=dev-api
export SMOKE_ENVIRONMENT=dev

