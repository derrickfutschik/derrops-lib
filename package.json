{
  "name": "slaops-platform",
  "version": "0.1.0",
  "private": true,
  "description": "SLA Ops client libraries - monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "test-resources"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:notify": "bash scripts/test-notify.sh",
    "test:watch": "turbo run test:watch",
    "test:watch:notify": "bash scripts/test-watch-notify.sh",
    "test:changed": "turbo run test:changed",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf packages/*/dist packages/*/node_modules node_modules",
    "clean:modules": "rm -rf node_modules packages/*/node_modules apps/*/node_modules test-resources/node_modules",
    "commit": "bash scripts/ai-commit.sh",
    "commit:ai": "bash scripts/ai-commit.sh",
    "setup:test-resources": "git clone git@github.com:APIs-guru/openapi-directory.git test-resources/openapi-directory",
    "amplify:sandbox": "pnpm -C packages/slaops-backend run sandbox",
    "amplify:deploy": "pnpm -C packages/slaops-backend run deploy",
    "amplify:clean": "rm -rf packages/slaops-backend/.amplify packages/slaops-backend/build",
    "infra:build": "pnpm -C packages/slaops-infra run build",
    "infra:synth": "pnpm -C packages/slaops-infra run synth",
    "infra:diff": "pnpm -C packages/slaops-infra run diff",
    "infra:deploy": "pnpm -C packages/slaops-infra run deploy",
    "infra:deploy:all": "pnpm -C packages/slaops-infra run deploy:all",
    "infra:destroy": "pnpm -C packages/slaops-infra run destroy",
    "infra:bootstrap": "pnpm -C packages/slaops-infra run bootstrap",
    "infra:clean": "rm -rf packages/slaops-infra/cdk.out"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.8",
    "jest": "^29.7.0",
    "node-notifier": "^10.0.1",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.0",
    "turbo": "^2.6.1",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@8.15.4+sha1.c85a4305534f76d461407b59277b954bac97b5c4",
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "js-yaml@<4.1.1": ">=4.1.1",
      "gray-matter>js-yaml": "3.14.1"
    }
  }
}
