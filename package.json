{
  "name": "slaops-platform",
  "version": "0.1.0",
  "private": true,
  "description": "SLA Ops client libraries - monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "test-resources"
  ],
  "scripts": {
    "build": "pnpm -r --filter @slaops/core run build && pnpm -r --filter @slaops/lib run build && pnpm -r --filter @slaops/client run build && pnpm -r --filter slaops-client-nodejs-axios run build && pnpm -r --filter slaops-docs run build && pnpm -r --filter vite_react_shadcn_ts run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules",
    "commit": "bash scripts/ai-commit.sh",
    "commit:ai": "bash scripts/ai-commit.sh",
    "setup:test-resources" : "git clone git@github.com:APIs-guru/openapi-directory.git test-resources/openapi-directory"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.8",
    "jest": "^29.7.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@8.15.4+sha1.c85a4305534f76d461407b59277b954bac97b5c4",
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "js-yaml@<4.1.1": ">=4.1.1"
    }
  }
}
