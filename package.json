{
  "name": "derrops-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Derrops client libraries - monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "test-resources"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:notify": "bash scripts/test-notify.sh",
    "test:watch": "turbo run test:watch",
    "test:watch:notify": "bash scripts/test-watch-notify.sh",
    "test:changed": "turbo run test:changed",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "sync:ts-paths": "node scripts/generate-workspace-ts-paths.mjs",
    "clean": "turbo run clean && rm -rf packages/*/dist packages/*/node_modules node_modules",
    "clean:modules": "rm -rf node_modules packages/*/node_modules apps/*/node_modules test-resources/node_modules",
    "format": "prettier --write .",
    "format:changed": "bash -c 'CHANGED=$(git diff --name-only --diff-filter=ACMR HEAD; git ls-files --others --exclude-standard); [ -n \"$CHANGED\" ] && echo \"$CHANGED\" | xargs prettier --write --ignore-unknown || true'",
    "format:staged": "bash -c 'STAGED=$(git diff --name-only --cached --diff-filter=ACMR); [ -n \"$STAGED\" ] && echo \"$STAGED\" | xargs prettier --write --ignore-unknown || true'",
    "format:organize": "prettier --write --plugin prettier-plugin-organize-imports .",
    "commit": "bash scripts/ai-commit.sh",
    "commit:ai": "bash scripts/ai-commit.sh",
    "subtree:list": "node scripts/subtree.mjs list",
    "subtree:pull": "node scripts/subtree.mjs pull",
    "subtree:push": "node scripts/subtree.mjs push",
    "subtree:add": "node scripts/subtree.mjs add",
    "subtree:create": "node scripts/subtree.mjs create",
    "setup:test-resources": "git clone git@github.com:APIs-guru/openapi-directory.git test-resources/openapi-directory",
    "amplify:sandbox": "pnpm -C packages/derrops-backend run sandbox",
    "amplify:deploy": "pnpm -C packages/derrops-backend run deploy",
    "amplify:clean": "rm -rf packages/derrops-backend/.amplify packages/derrops-backend/build",
    "infra:build": "pnpm -C packages/derrops-infra run build",
    "infra:synth": "pnpm -C packages/derrops-infra run synth",
    "infra:diff": "pnpm -C packages/derrops-infra run diff",
    "infra:deploy": "pnpm -C packages/derrops-infra run deploy",
    "infra:deploy:all": "pnpm -C packages/derrops-infra run deploy:all",
    "infra:destroy": "pnpm -C packages/derrops-infra run destroy",
    "infra:bootstrap": "pnpm -C packages/derrops-infra run bootstrap",
    "infra:clean": "rm -rf packages/derrops-infra/cdk.out"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.7.8",
    "jest": "^29.7.0",
    "node-notifier": "^10.0.1",
    "prettier": "^3.3.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.3.0",
    "turbo": "^2.9.14",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@8.15.4+sha1.c85a4305534f76d461407b59277b954bac97b5c4",
  "pnpm": {
    "overrides": {
      "esbuild@<=0.24.2": ">=0.25.0",
      "js-yaml@<4.1.1": ">=4.1.1",
      "gray-matter>js-yaml": "3.14.1",
      "baseline-browser-mapping": "2.10.29",
      "caniuse-lite": "1.0.30001792"
    }
  }
}
