{
  "name": "slaops-platform",
  "version": "0.1.0",
  "private": true,
  "description": "SLA Ops client libraries - monorepo",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "pnpm -r --filter @slaops/core run build && pnpm -r --filter @slaops/lib run build && pnpm -r --filter @slaops/client run build && pnpm -r --filter slaops-client-nodejs-axios run build && pnpm -r --filter slaops-docs run build",
    "dev": "pnpm -r run dev",
    "test": "pnpm -r run test",
    "test:watch": "pnpm -r run test:watch",
    "clean": "rm -rf packages/*/dist packages/*/node_modules node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.7.8",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=18.17",
    "npm": ">=9.0.0"
  },
  "packageManager": "pnpm@8.15.4+sha1.c85a4305534f76d461407b59277b954bac97b5c4"
}
